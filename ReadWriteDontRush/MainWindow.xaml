<Window x:Class="ReadWriteDontRush.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReadWriteDontRush"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="LightGray">

            <Button x:Name="CatalogBtn"
                    Content="Каталог"
                    Height="40"
                    Margin="10"
                    Click="CatalogBtn_Click"/>

            <Button x:Name="ProfileBtn"
                    Content="Профиль"
                    Height="40"
                    Margin="10"
                    Click="ProfileBtn_Click"/>

            <Button x:Name="AuthorBtn"
                    Content="Автор"
                    Height="40"
                    Margin="10"
                    Visibility="Collapsed"
                    Click="AuthorBtn_Click"/>

            <Button x:Name="AdminBtn"
                    Content="Админ"
                    Height="40"
                    Margin="10"
                    Visibility="Collapsed"
                    Click="AdminBtn_Click"/>

        </StackPanel>

        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
