<Page x:Class="ReadWriteDontRush.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorPage" Background="White">

    <Page.Resources>
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>
    </Page.Resources>

    <Grid Background="#E8ECEF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с градиентом -->
        <Border Grid.Row="0" Background="#1E2A38" Padding="20" CornerRadius="0">
            <TextBlock Text="✍️ Страница автора" FontSize="28" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Панель управления с тенью -->
        <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,15" 
                CornerRadius="0" >
            <Border.Resources>
                <DropShadowEffect x:Key="HeaderShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
            </Border.Resources>
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                    <Button x:Name="BtnMyBooks" Content="📚 Мои книги" Width="160" Height="44" 
                            Background="#3498DB" Foreground="White" Margin="8" FontWeight="SemiBold" FontSize="13"
                            Cursor="Hand" BorderThickness="0" Click="BtnMyBooks_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnAddBook" Content="➕ Добавить книгу" Width="160" Height="44" 
                            Background="#27AE60" Foreground="White" Margin="8" FontWeight="SemiBold" FontSize="13"
                            Cursor="Hand" BorderThickness="0" Click="BtnAddBook_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnFrozenBooks" Content="❄️ Замороженные книги" Width="190" Height="44" 
                            Background="#E74C3C" Foreground="White" Margin="8" FontWeight="SemiBold" FontSize="13"
                            Cursor="Hand" BorderThickness="0" Click="BtnFrozenBooks_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Список книг -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksItemsControl" Margin="15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="230" Style="{StaticResource BookCardStyle}">
                            <StackPanel>
                                <!-- Обложка -->
                                <Border Height="290" Background="#F0F2F5" CornerRadius="12,12,0,0">
                                    <Image Width="210" Height="270" Margin="10,10,10,10"
                                           Stretch="UniformToFill">
                                        <Image.Source>
                                            <Binding Path="CoverImagePath">
                                            </Binding>
                                        </Image.Source>
                                    </Image>
                                </Border>

                                <!-- Информация о книге -->
                                <StackPanel Margin="12" Height="170">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                               FontSize="15" TextWrapping="Wrap"
                                               Margin="0,0,0,8" Foreground="#1E2A38"/>

                                    <!-- Рейтинг -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="★" Foreground="#F1C40F" FontSize="16"/>
                                        <TextBlock Text="{Binding AverageRating, StringFormat={}{0:F1}}" 
                                                   FontSize="13" Margin="6,0,0,0" Foreground="#555"/>
                                        <TextBlock Text="{Binding ReviewsCount, StringFormat='({0})'}" 
                                                   FontSize="11" Foreground="#95A5A6" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <!-- Жанры -->
                                    <TextBlock Text="{Binding GenresString}" FontSize="11" 
                                               Foreground="#7F8C8D" TextWrapping="Wrap"
                                               MaxHeight="38" Margin="0,0,0,6"/>

                                    <!-- Дата -->
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='📅 {0:dd.MM.yyyy}'}" 
                                               FontSize="11" Foreground="#95A5A6" Margin="0,5,0,8"/>

                                    <!-- Кнопки действий -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="✏️ Редактировать" Width="110" Height="34"
                                                Background="#F39C12" Foreground="White" FontSize="11"
                                                Cursor="Hand" BorderThickness="0" Click="BtnEditBook_Click" Tag="{Binding}"
                                                Visibility="{Binding ShowEditButton}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Button x:Name="BtnAppealFreeze" Content="📢 Оспорить заморозку" Width="125" Height="34"
                                                Margin="8,0,0,0" Background="#E67E22" Foreground="White" FontSize="10"
                                                Cursor="Hand" BorderThickness="0" Click="BtnAppealFreeze_Click" Tag="{Binding BookID}"
                                                Visibility="{Binding ShowAppealButton}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <TextBlock x:Name="TxtAppealSent" Text="✓ Заявка отправлена" 
                                                   FontSize="11" Foreground="#27AE60" Margin="10,8,0,0" FontWeight="SemiBold"
                                                   Visibility="{Binding ShowAppealSentText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Пустое сообщение -->
        <TextBlock x:Name="TxtEmptyMessage" Grid.Row="2" 
                   Text="📭 У вас пока нет книг" 
                   FontSize="18" Foreground="#95A5A6" FontWeight="SemiBold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Page>
