<Page x:Class="ReadWriteDontRush.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorPage" Background="White">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">

            <Button Content="Добавить книгу"
                    Width="150"
                    Height="35"
                    Margin="0 0 10 0"
                    Click="AddBookBtn_Click"/>

            <Button Content="Удалить книгу"
                    Width="150"
                    Height="35"
                    Click="DeleteBookBtn_Click"/>

        </StackPanel>

        <DataGrid x:Name="BooksGrid"
                  Grid.Row="1"
                  Margin="0 10 0 0"
                  AutoGenerateColumns="True"/>

    </Grid>

</Page>
