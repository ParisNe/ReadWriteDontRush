<Page x:Class="ReadWriteDontRush.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верх -->
        <Border Grid.Row="0"
                Background="White"
                Padding="20"
                BorderBrush="#E5E5E5"
                BorderThickness="0,0,0,1">

            <StackPanel>

                <TextBlock Text="Панель автора"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#222"/>

                <WrapPanel Margin="0,18,0,0">

                    <Button x:Name="BtnAddBook"
                            Content="Добавить книгу"
                            Width="170"
                            Height="38"
                            Margin="0,0,10,0"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnAddBook_Click"/>

                    <Button x:Name="BtnMyBooks"
                            Content="Мои книги"
                            Width="130"
                            Height="38"
                            Margin="0,0,10,0"
                            Background="#EAEAEA"
                            Foreground="#222"
                            BorderThickness="0"
                            Click="BtnMyBooks_Click"/>

                    <Button x:Name="BtnFrozenBooks"
                            Content="Замороженные"
                            Width="160"
                            Height="38"
                            Background="#EAEAEA"
                            Foreground="#222"
                            BorderThickness="0"
                            Click="BtnFrozenBooks_Click"/>

                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- Контент -->
        <Frame x:Name="AuthorContentFrame"
               Grid.Row="1"
               Margin="20"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
