<Page x:Class="ReadWriteDontRush.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="✍️ Панель автора" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <WrapPanel Margin="0,10,0,0">
                    <Button x:Name="BtnAddBook" Content="➕ Добавить новую книгу" 
                            Background="#27AE60" Foreground="White" Height="40" Width="200"
                            Margin="0,0,10,0" Click="BtnAddBook_Click"/>
                    <Button x:Name="BtnMyBooks" Content="📚 Мои книги" 
                            Background="#3498DB" Foreground="White" Height="40" Width="150"
                            Margin="0,0,10,0" Click="BtnMyBooks_Click"/>
                    <Button x:Name="BtnFrozenBooks" Content="❄️ Замороженные книги" 
                            Background="#E67E22" Foreground="White" Height="40" Width="200"
                            Click="BtnFrozenBooks_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Frame x:Name="AuthorContentFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
