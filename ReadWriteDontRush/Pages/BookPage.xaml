<Page x:Class="ReadWriteDontRush.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookPage" Background="White">

    <ScrollViewer>

        <StackPanel Margin="10">

            <Image x:Name="CoverImage"
                   Width="150"
                   Height="200"
                   Margin="0,0,0,10"/>

            <TextBlock x:Name="TitleText"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBlock x:Name="AuthorText"
                       Margin="0,5"/>

            <TextBlock x:Name="GenresText"
                       Margin="0,5"/>

            <TextBlock x:Name="DescriptionText"
                       TextWrapping="Wrap"
                       Margin="0,10"/>

            <TextBlock Text="Текст книги"
                       FontWeight="Bold"
                       Margin="0,10"/>

            <TextBox x:Name="ContentText"
                     Height="300"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,10">

                <Button Content="Жалоба на книгу"
                        Click="ComplainBook_Click"
                        Margin="5"/>

                <Button Content="Жалоба на автора"
                        Click="ComplainAuthor_Click"
                        Margin="5"/>

            </StackPanel>

            <TextBlock Text="Отзывы"
                       FontSize="18"
                       Margin="0,15,0,10"/>

            <ItemsControl x:Name="ReviewsList"/>

            <TextBlock Text="Добавить отзыв"
                       Margin="0,15,0,5"/>

            <ComboBox x:Name="RatingBox"
                      Width="100"
                      Margin="0,5"/>

            <TextBox x:Name="ReviewText"
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <Button Content="Отправить"
                    Margin="0,10"
                    Click="SubmitReview_Click"/>

        </StackPanel>

    </ScrollViewer>


</Page>
