<Page x:Class="ReadWriteDontRush.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookPage" Background="White">

    <ScrollViewer>

        <StackPanel Margin="20">

            <TextBlock x:Name="TitleTb"
                       FontSize="28"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Описание"/>

            <TextBox x:Name="DescTb"
                     Height="100"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     Margin="0 5 0 20"/>

            <TextBlock Text="Текст книги"/>

            <TextBox x:Name="ContentTb"
                     Height="250"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Margin="0 5 0 20"/>

            <TextBlock Text="Отзывы"/>

            <DataGrid x:Name="ReviewsGrid"
                      Height="200"
                      Margin="0 5 0 20"/>

            <TextBlock Text="Ваш отзыв"/>

            <TextBox x:Name="ReviewTb"
                     Height="100"
                     AcceptsReturn="True"
                     Margin="0 5 0 20"/>

            <Button Content="Добавить отзыв"
                    Width="200"
                    Height="35"
                    Click="AddReviewBtn_Click"/>

        </StackPanel>

    </ScrollViewer>

</Page>
