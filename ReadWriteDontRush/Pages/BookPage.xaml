<Page x:Class="ReadWriteDontRush.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookPage" Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Информация о книге -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Обложка -->
                    <Border Grid.Column="0"
                            Height="320"
                            Background="#E5E7EB"
                            CornerRadius="6"
                            Margin="0,0,20,0">

                        <Image x:Name="BookCover"
                               Stretch="UniformToFill"/>
                    </Border>

                    <!-- Информация -->
                    <StackPanel Grid.Column="1">

                        <TextBlock x:Name="TxtTitle"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="TxtAuthor"
                                   FontSize="15"
                                   Foreground="#6B7280"
                                   Margin="0,0,0,8"/>

                        <TextBlock x:Name="TxtGenres"
                                   FontSize="13"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,14"/>

                        <!-- Рейтинг -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">

                            <TextBlock x:Name="TxtRating"
                                       FontSize="16"
                                       Foreground="#6B7280"/>

                            <TextBlock x:Name="TxtReviewsCount"
                                       FontSize="12"
                                       Foreground="#9CA3AF"
                                       Margin="10,3,0,0"/>
                        </StackPanel>

                        <!-- Описание -->
                        <TextBlock Text="Описание"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,6"/>

                        <TextBlock x:Name="TxtDescription"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#374151"
                                   Margin="0,0,0,20"
                                   MaxHeight="100"/>

                        <!-- Кнопки -->
                        <WrapPanel>

                            <Button x:Name="BtnAddToList"
                                    Content="В мой список"
                                    Width="130"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Background="#374151"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="BtnAddToList_Click"/>

                            <Button x:Name="BtnComplainBook"
                                    Content="Жалоба на книгу"
                                    Width="150"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Background="#E5E7EB"
                                    Foreground="#374151"
                                    BorderThickness="0"
                                    Click="BtnComplainBook_Click"/>

                            <Button x:Name="BtnComplainAuthor"
                                    Content="Жалоба на автора"
                                    Width="160"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Background="#E5E7EB"
                                    Foreground="#374151"
                                    BorderThickness="0"
                                    Click="BtnComplainAuthor_Click"/>

                            <Button x:Name="BtnFreezeBook"
                                    Content="Заморозить книгу"
                                    Width="160"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Background="#D1D5DB"
                                    Foreground="#111827"
                                    BorderThickness="0"
                                    Visibility="Collapsed"
                                    Click="BtnFreezeBook_Click"/>

                        </WrapPanel>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- Текст книги -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="28"
                    Margin="0,0,0,16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Текст книги"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,16"/>

                    <ScrollViewer MaxHeight="500"
                                  VerticalScrollBarVisibility="Auto">

                        <TextBlock x:Name="TxtBookContent"
                                   FontSize="16"
                                   LineHeight="26"
                                   TextWrapping="Wrap"
                                   FontFamily="Segoe UI"
                                   Foreground="#374151"/>

                    </ScrollViewer>

                </StackPanel>

            </Border>

            <!-- Отзывы -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="8"
                    Padding="24"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Отзывы"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,16"/>

                    <!-- Добавление отзыва -->
                    <Border Background="#F9FAFB"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,20"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">

                        <StackPanel>

                            <TextBlock Text="Оставить отзыв"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,12">

                                <TextBlock Text="Оценка:"
                                           VerticalAlignment="Center"
                                           Foreground="#374151"
                                           Margin="0,0,10,0"/>

                                <ComboBox x:Name="CmbRating"
                                          Width="100"
                                          SelectedIndex="0">

                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>

                                </ComboBox>

                            </StackPanel>

                            <TextBox x:Name="TxtReview"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,12"/>

                            <Button x:Name="BtnSubmitReview"
                                    Content="Отправить отзыв"
                                    Width="160"
                                    Height="36"
                                    Background="#374151"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="BtnSubmitReview_Click"/>

                        </StackPanel>

                    </Border>

                    <!-- Список отзывов -->
                    <ItemsControl x:Name="ReviewsItemsControl">

                        <ItemsControl.ItemTemplate>

                            <DataTemplate>

                                <Border Background="#F9FAFB"
                                        CornerRadius="6"
                                        Padding="16"
                                        Margin="0,0,0,10"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Текст -->
                                        <StackPanel Grid.Column="0">

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,6">

                                                <TextBlock Text="{Binding UserName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#111827"/>

                                                <TextBlock Text="{Binding CreatedAt, StringFormat=' dd.MM.yyyy'}"
                                                           FontSize="11"
                                                           Foreground="#9CA3AF"
                                                           Margin="10,1,0,0"/>

                                            </StackPanel>

                                            <TextBlock Text="{Binding Rating}"
                                                       FontSize="12"
                                                       Foreground="#6B7280"
                                                       Margin="0,0,0,8"/>

                                            <TextBlock Text="{Binding ReviewText}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#374151"/>

                                        </StackPanel>

                                        <!-- Кнопки -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal">

                                            <Button Content="Жалоба"
                                                    Width="80"
                                                    Height="30"
                                                    Background="#E5E7EB"
                                                    Foreground="#374151"
                                                    BorderThickness="0"
                                                    Click="BtnComplainReview_Click"
                                                    Tag="{Binding ReviewID}"/>

                                            <Button x:Name="BtnFreezeReview"
                                                    Content="Заморозить"
                                                    Width="100"
                                                    Height="30"
                                                    Margin="6,0,0,0"
                                                    Background="#D1D5DB"
                                                    Foreground="#111827"
                                                    BorderThickness="0"
                                                    Visibility="Collapsed"
                                                    Click="BtnFreezeReview_Click"
                                                    Tag="{Binding ReviewID}"/>

                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>

            </Border>

        </Grid>

    </ScrollViewer>
</Page>
