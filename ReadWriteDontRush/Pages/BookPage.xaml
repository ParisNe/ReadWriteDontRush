<Page x:Class="ReadWriteDontRush.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookPage" Background="White">

    <ScrollViewer>

        <StackPanel Margin="20" >

            <TextBlock x:Name="TbTitle"
                       FontSize="28"/>

            <TextBlock Text="Описание"
                       FontSize="18"
                       Margin="0 20 0 10"/>

            <TextBlock x:Name="TbDescription"/>

            <Button Content="Читать"
                    Width="150"
                    Height="35"
                    Margin="0 20 0 0"/>

            <Button Content="Пожаловаться"
                    Width="150"
                    Height="35"
                    Margin="0 10 0 0"/>

            <DataGrid x:Name="ReviewsGrid"
                      Margin="0 20 0 0"/>

        </StackPanel>

    </ScrollViewer>

</Page>
