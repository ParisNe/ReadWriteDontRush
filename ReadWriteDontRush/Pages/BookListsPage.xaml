<Page x:Class="ReadWriteDontRush.Pages.BookListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookListsPage" Background="White">

    <Page.Resources>
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListTabButton" TargetType="Button">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="15">
            <TextBlock Text="📚 Мои списки книг" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <!-- Табы для переключения списков -->
        <WrapPanel Grid.Row="1" Background="White" Margin="0,0,0,10">
            <Button x:Name="BtnWantToRead" Style="{StaticResource ListTabButton}" 
                    Click="BtnList_Click" Tag="1" BorderBrush="#3498DB" BorderThickness="0,0,0,3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📖 В планах" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TxtWantToReadCount" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtnReading" Style="{StaticResource ListTabButton}" 
                    Click="BtnList_Click" Tag="2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📚 Читаю" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TxtReadingCount" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtnRead" Style="{StaticResource ListTabButton}" 
                    Click="BtnList_Click" Tag="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✅ Прочитано" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TxtReadCount" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button x:Name="BtnDropped" Style="{StaticResource ListTabButton}" 
                    Click="BtnList_Click" Tag="4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❌ Заброшено" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TxtDroppedCount" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <!-- Панель поиска и фильтров -->
        <Border Grid.Row="2" Background="White" Padding="15" Margin="10,0,10,10" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="🔍 Поиск" FontSize="12" Foreground="Gray"/>
                    <TextBox x:Name="TxtSearch" Height="35" Margin="0,5,0,0" 
                             TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="📊 Сортировка" FontSize="12" Foreground="Gray"/>
                    <ComboBox x:Name="CmbSort" Height="35" SelectedIndex="0"
                              SelectionChanged="CmbSort_SelectionChanged">
                        <ComboBoxItem Content="По названию (А-Я)"/>
                        <ComboBoxItem Content="По названию (Я-А)"/>
                        <ComboBoxItem Content="По рейтингу (высокий)"/>
                        <ComboBoxItem Content="По рейтингу (низкий)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="🎭 Фильтр по жанру" FontSize="12" Foreground="Gray"/>
                    <ComboBox x:Name="CmbGenre" Height="35" 
                              SelectionChanged="CmbGenre_SelectionChanged"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Сбросить" Width="80" Height="35" 
                        Margin="10,22,0,0" Background="#E74C3C" Foreground="White"
                        Click="BtnReset_Click"/>
            </Grid>
        </Border>

        <!-- Сетка книг -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <ItemsControl x:Name="BooksItemsControl" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Style="{StaticResource BookCardStyle}">
                            <StackPanel>
                                <Border Height="250" Background="#ECF0F1" CornerRadius="8,8,0,0">
                                    <Image Width="180" Height="230" Margin="10">
                                        <Image.Source>
                                            <Binding Path="CoverImagePath"/>
                                        </Image.Source>
                                    </Image>
                                </Border>

                                <StackPanel Margin="10" Height="140">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                               FontSize="14" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding AuthorName}" FontSize="11" 
                                               Foreground="Gray" Margin="0,5,0,5"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="★" Foreground="Gold" FontSize="14"/>
                                        <TextBlock Text="{Binding AverageRating, StringFormat={}{0:F1}}" 
                                                   FontSize="12" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding GenresString}" FontSize="10" 
                                               Foreground="#7F8C8D" TextWrapping="Wrap" MaxHeight="40"/>

                                    <ComboBox x:Name="CmbChangeList" SelectedValue="{Binding CurrentListTypeId}"
                                              SelectionChanged="CmbChangeList_SelectionChanged"
                                              Margin="0,10,0,0" Height="30">
                                        <ComboBoxItem Content="📖 В планах" Tag="1"/>
                                        <ComboBoxItem Content="📚 Читаю" Tag="2"/>
                                        <ComboBoxItem Content="✅ Прочитано" Tag="3"/>
                                        <ComboBoxItem Content="❌ Заброшено" Tag="4"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
