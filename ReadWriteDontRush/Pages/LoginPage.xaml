<Page x:Class="ReadWriteDontRush.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage" Background="White">

    <Grid>

        <Border Width="420"
                Padding="35"
                Background="White"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="2"
                                  Opacity="0.12"/>
            </Border.Effect>

            <StackPanel>
                <!-- Вкладки -->
                <TabControl Background="Transparent"
                            BorderThickness="0">

                    <!-- Вход -->
                    <TabItem Header="Вход">

                        <StackPanel Margin="10,20,10,0">

                            <TextBlock Text="Логин"
                                       Margin="0,0,0,6"
                                       FontSize="14"
                                       Foreground="Black"/>

                            <TextBox x:Name="TxtLogin"
                                     Height="42"
                                     Padding="10"
                                     FontSize="14"
                                     BorderBrush="#D0D7DE"
                                     BorderThickness="1"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="Пароль"
                                       Margin="0,0,0,6"
                                       FontSize="14"
                                       Foreground="Black"/>

                            <PasswordBox x:Name="TxtPassword"
                                         Height="42"
                                         Padding="10"
                                         FontSize="14"
                                         BorderBrush="#D0D7DE"
                                         BorderThickness="1"
                                         Margin="0,0,0,24"/>

                            <Button Content="Войти"
                                    Height="45"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="Purple"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnLogin_Click"/>

                        </StackPanel>
                    </TabItem>

                    <!-- Регистрация -->
                    <TabItem Header="Регистрация">

                        <StackPanel Margin="10,20,10,0">

                            <TextBlock Text="Логин"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>

                            <TextBox x:Name="TxtRegLogin"
                                     Height="42"
                                     Padding="10"
                                     Margin="0,0,0,14"/>

                            <TextBlock Text="Пароль"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>

                            <PasswordBox x:Name="TxtRegPassword"
                                         Height="42"
                                         Padding="10"
                                         Margin="0,0,0,14"/>

                            <TextBlock Text="Подтверждение пароля"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>

                            <PasswordBox x:Name="TxtConfirmPassword"
                                         Height="42"
                                         Padding="10"
                                         Margin="0,0,0,14"/>

                            <TextBlock Text="Имя пользователя"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>

                            <TextBox x:Name="TxtDisplayName"
                                     Height="42"
                                     Padding="10"
                                     Margin="0,0,0,14"/>

                            <TextBlock Text="Email"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>

                            <TextBox x:Name="TxtEmail"
                                     Height="42"
                                     Padding="10"
                                     Margin="0,0,0,24"/>

                            <Button Content="Создать аккаунт"
                                    Height="45"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Background="#10B981"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnRegister_Click"/>

                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </Border>
    </Grid>
</Page>
