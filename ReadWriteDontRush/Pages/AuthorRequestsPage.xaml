<Page x:Class="ReadWriteDontRush.Pages.AuthorRequestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Заявки авторов" Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✍️ Заявки на получение роли автора" FontSize="22" FontWeight="Bold" 
                   Margin="0,0,0,20" Foreground="#2C3E50"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RequestsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8" Padding="15" 
                                Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock FontWeight="Bold" FontSize="14">
                                            <Run Text="Пользователь: "/>
                                            <Run Text="{Binding UserLogin}" Foreground="#3498DB"/>
                                        </TextBlock>
                                        <TextBlock Margin="15,0,0,0" FontSize="12" Foreground="Gray">
                                            <Run Text="(" />
                                            <Run Text="{Binding UserDisplayName}"/>
                                            <Run Text=")"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                               FontSize="11" Foreground="Gray"/>
                                </Grid>

                                <TextBlock Margin="0,10,0,5" FontWeight="Bold">Сообщение от пользователя:</TextBlock>
                                <Border Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                                </Border>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="✅ Принять" Width="100" Height="35" 
                                            Background="#27AE60" Foreground="White" Margin="0,0,10,0"
                                            Click="AcceptRequest_Click" Tag="{Binding RequestID}"/>
                                    <Button Content="❌ Отклонить" Width="100" Height="35"
                                            Background="#E74C3C" Foreground="White"
                                            Click="RejectRequest_Click" Tag="{Binding RequestID}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="TxtNoItems" Grid.Row="1" Text="Нет заявок на рассмотрении" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="16" Foreground="Gray" Visibility="Collapsed"/>
    </Grid>
</Page>
