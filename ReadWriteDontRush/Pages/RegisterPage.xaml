<Page x:Class="ReadWriteDontRush.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage" Background="White">

    <Grid>

        <StackPanel Width="350"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock Text="Регистрация"
                       FontSize="24"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Имя"/>
            <TextBox x:Name="NameTb"
                     Height="30"
                     Margin="0 5 0 10"/>

            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginTb"
                     Height="30"
                     Margin="0 5 0 10"/>

            <TextBlock Text="Почта"/>
            <TextBox x:Name="EmailTb"
                     Height="30"
                     Margin="0 5 0 10"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordTb"
                         Height="30"
                         Margin="0 5 0 20"/>

            <Button Content="Создать аккаунт"
                    Height="35"
                    Click="RegisterBtn_Click"/>

        </StackPanel>

    </Grid>
</Page>
