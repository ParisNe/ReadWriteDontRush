<Page x:Class="ReadWriteDontRush.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
            <Border Background="White" CornerRadius="15" Padding="35" 
                    BorderBrush="#2C3E50" BorderThickness="2" Margin="20"
                    >
                <Border.Resources>
                    <DropShadowEffect x:Key="ShadowEffect" BlurRadius="15" ShadowDepth="3" Opacity="0.15"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="📝 Регистрация" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,25"
                               Foreground="#1E2A38"/>

                    <TextBlock Text="Логин" Margin="0,5,0,5" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox Name="txtLogin" Height="38" FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <TextBlock Text="Email" Margin="0,15,0,5" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox Name="txtEmail" Height="38" FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <TextBlock Text="Отображаемое имя" Margin="0,15,0,5" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox Name="txtDisplayName" Height="38" FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <TextBlock Text="Пароль" Margin="0,15,0,5" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <PasswordBox Name="txtPassword" Height="38" FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <TextBlock Text="Подтверждение пароля" Margin="0,15,0,5" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <PasswordBox Name="txtConfirmPassword" Height="38" FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <Button Name="btnRegister" 
                            Content="Зарегистрироваться" 
                            Background="#27AE60"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Bold"
                            Height="45" 
                            Margin="0,25,0,10"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnRegister_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Name="btnBack" 
                            Content="← Назад к входу" 
                            Background="Transparent" 
                            Foreground="#3498DB" 
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,8"
                            Click="btnBack_Click"/>

                    <TextBlock Name="txtError" 
                               Foreground="#E74C3C" 
                               HorizontalAlignment="Center" 
                               Margin="0,15"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
