<Page x:Class="ReadWriteDontRush.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
            <Border Background="White" CornerRadius="10" Padding="30" 
                    BorderBrush="#DDD" BorderThickness="1" Margin="20">
                <StackPanel>
                    <TextBlock Text="📝 Регистрация" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"
                               Foreground="#2C3E50"/>

                    <TextBlock Text="Логин" Margin="0,5,0,0"/>
                    <TextBox Name="txtLogin" />

                    <TextBlock Text="Email" Margin="0,15,0,0"/>
                    <TextBox Name="txtEmail"/>

                    <TextBlock Text="Отображаемое имя" Margin="0,15,0,0"/>
                    <TextBox Name="txtDisplayName" />

                    <TextBlock Text="Пароль" Margin="0,15,0,0"/>
                    <PasswordBox Name="txtPassword" />

                    <TextBlock Text="Подтверждение пароля" Margin="0,15,0,0"/>
                    <PasswordBox Name="txtConfirmPassword" />

                    <Button Name="btnRegister" 
                            Content="Зарегистрироваться" 
                           
                            Height="40" 
                            Margin="0,20,0,10"
                            Click="btnRegister_Click"/>

                    <Button Name="btnBack" 
                            Content="← Назад к входу" 
                            Background="Transparent" 
                            Foreground="#666" 
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,5"
                            Click="btnBack_Click"/>

                    <TextBlock Name="txtError" 
                               Foreground="Red" 
                               HorizontalAlignment="Center" 
                               Margin="0,10"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
