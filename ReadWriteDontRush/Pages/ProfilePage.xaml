<Page x:Class="ReadWriteDontRush.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage" Background="White">

    <ScrollViewer>

        <StackPanel Margin="20">

            <TextBlock Text="Профиль"
                       FontSize="24"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="UsernameText"/>
            <TextBlock x:Name="EmailText"
                       Margin="0,5"/>

            <TextBlock x:Name="RoleText"
                       Margin="0,5"/>

            <TextBlock x:Name="FreezeReasonText"
                       Foreground="Red"
                       Margin="0,10"/>

            <Button Content="Подать заявку на автора"
                    Width="200"
                    Margin="0,10"
                    Click="AuthorRequest_Click"/>

            <TextBlock Text="Мои отзывы"
                       FontSize="18"
                       Margin="0,20,0,10"/>

            <ItemsControl x:Name="ReviewsList"/>

        </StackPanel>

    </ScrollViewer>

</Page>
