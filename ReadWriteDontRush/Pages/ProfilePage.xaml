<Page x:Class="ReadWriteDontRush.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="#F5F5F5" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Информация о пользователе -->
            <Border Grid.Row="0" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Профиль пользователя" FontSize="24" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <TextBlock x:Name="TxtLogin" Grid.Row="0" Grid.Column="1" 
                                   Margin="0,0,0,10" FontSize="14"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Отображаемое имя:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <TextBlock x:Name="TxtDisplayName" Grid.Row="1" Grid.Column="1" 
                                   Margin="0,0,0,10" FontSize="14"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <TextBlock x:Name="TxtEmail" Grid.Row="2" Grid.Column="1" 
                                   Margin="0,0,0,10" FontSize="14"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Роль:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <TextBlock x:Name="TxtRole" Grid.Row="3" Grid.Column="1" 
                                   Margin="0,0,0,10" FontSize="14"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата регистрации:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <TextBlock x:Name="TxtCreatedAt" Grid.Row="4" Grid.Column="1" 
                                   Margin="0,0,0,10" FontSize="14"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock x:Name="TxtStatus" FontSize="14" Margin="0,0,10,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Заявка на роль:" FontWeight="Bold" 
                                   Margin="0,0,10,10" FontSize="14"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <ComboBox x:Name="CmbRequestRole" Width="150" Height="30" Margin="0,0,10,0">
                                <ComboBoxItem Content="Автор" Tag="2"/>
                                <ComboBoxItem Content="Администратор" Tag="3"/>
                            </ComboBox>
                            <Button x:Name="BtnRequestRole" Content="Подать заявку на смену роли" 
                                    Width="220" Height="30" Background="#3498DB" Foreground="White"
                                    Click="BtnRequestRole_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Предупреждение о заморозке -->
                    <Border x:Name="BorderFreezeWarning" Background="#FFE6E6" 
                            CornerRadius="5" Padding="15" Margin="0,20,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="⚠️ ВНИМАНИЕ: АККАУНТ ЗАМОРОЖЕН" 
                                       FontWeight="Bold" Foreground="#E74C3C" 
                                       Margin="0,0,0,10" FontSize="14"/>
                            <TextBlock x:Name="TxtFreezeReason" TextWrapping="Wrap" 
                                       Margin="0,0,0,10" FontSize="13"/>
                            <Button x:Name="BtnAppealFreeze" Content="Оспорить заморозку" 
                                    Width="150" Height="30" Background="#E67E22" 
                                    Foreground="White" Click="BtnAppealFreeze_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Информация о статусе заявки -->
                    <Border x:Name="BorderRequestStatus" Background="#E8F8F5" 
                            CornerRadius="5" Padding="15" Margin="0,20,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="TxtRequestStatus" TextWrapping="Wrap" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Отзывы пользователя -->
            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Мои отзывы" FontSize="20" FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <ItemsControl x:Name="ReviewsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" CornerRadius="5" 
                                        Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="Bold" FontSize="14">
                                                <Run Text="Книга: "/>
                                                <Run Text="{Binding Books.Title}" 
                                                     Foreground="#3498DB"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                                <TextBlock Text="★" Foreground="Gold" FontSize="14"/>
                                                <TextBlock Text="{Binding Rating}" FontSize="12" Margin="5,0,0,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat=' | {0:dd.MM.yyyy}'}" 
                                                           FontSize="11" Foreground="Gray" Margin="10,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ReviewText}" 
                                                       TextWrapping="Wrap" MaxHeight="100"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" Content="К книге" 
                                                Width="80" Height="30"
                                                Background="#2C3E50" Foreground="White"
                                                Click="BtnGoToBook_Click" 
                                                Tag="{Binding BookID}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtNoReviews" Text="У вас пока нет отзывов" 
                               FontSize="14" Foreground="Gray"
                               HorizontalAlignment="Center" Margin="20"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
