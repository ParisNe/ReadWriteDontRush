<Page x:Class="ReadWriteDontRush.Pages.AddEditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditBookPage" Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="#F5F5F5" Margin="20">
            <Border Background="White" CornerRadius="10" Padding="30">
                <StackPanel>
                    <TextBlock x:Name="TxtTitle" Text="Добавление новой книги" 
                               FontSize="24" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Название книги" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtBookTitle" Height="35" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtDescription" Height="100" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Жанры" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ListBox x:Name="ListGenres" Height="120" 
                             SelectionMode="Multiple" Margin="0,0,0,15">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding GenreName}" 
                                          Tag="{Binding GenreID}"
                                          Checked="GenreCheckBox_Checked"
                                          Unchecked="GenreCheckBox_Unchecked"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="Путь к обложке (опционально)" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCoverPath" Grid.Column="0" Height="35" Padding="5"/>
                        <Button x:Name="BtnBrowseCover" Grid.Column="1" Content="Обзор" 
                                Width="80" Margin="10,0,0,0" Click="BtnBrowseCover_Click"/>
                    </Grid>

                    <TextBlock Text="Текст книги" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtContent" Height="300" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="0,0,0,20" 
                             VerticalScrollBarVisibility="Auto" Padding="5"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnSave" Content="Сохранить" Width="120" Height="40"
                                Background="#27AE60" Foreground="White" Margin="5"
                                Click="BtnSave_Click"/>
                        <Button x:Name="BtnCancel" Content="Отмена" Width="120" Height="40"
                                Background="#95A5A6" Foreground="White" Margin="5"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
