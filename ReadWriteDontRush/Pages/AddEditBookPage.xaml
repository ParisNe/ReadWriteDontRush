<Page x:Class="ReadWriteDontRush.Pages.AddEditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditBookPage" Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="📖 Добавление новой книги" 
                           FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

                <!-- Название -->
                <TextBlock Text="Название книги" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtTitle" Height="40" Margin="0,0,0,15"/>

                <!-- Автор -->
                <TextBlock Text="Автор" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbAuthor" Height="40" Margin="0,0,0,15" DisplayMemberPath="DisplayName"
                          SelectedValuePath="UserID"/>

                <!-- Описание -->
                <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtDescription" Height="100" TextWrapping="Wrap" 
                         AcceptsReturn="True" Margin="0,0,0,15"/>

                <!-- Текст книги -->
                <TextBlock Text="Текст книги" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtContent" Height="200" TextWrapping="Wrap" 
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                         Margin="0,0,0,15"/>

                <!-- Путь к обложке -->
                <TextBlock Text="Путь к изображению обложки" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtCoverPath" Height="40" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="Обзор" Width="60" Height="35" 
                            Background="#3498DB" Foreground="White" Click="BtnBrowse_Click"/>
                </Grid>

                <!-- Жанры -->
                <TextBlock Text="Жанры" FontWeight="Bold" Margin="0,15,0,5"/>
                <ListBox x:Name="LstGenres" Height="120" SelectionMode="Multiple"
                         DisplayMemberPath="GenreName" Margin="0,0,0,15"/>

                <!-- Предпросмотр обложки -->
                <Border Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Предпросмотр обложки" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Image x:Name="ImgPreview" Height="200" Stretch="Uniform"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnSave" Content="💾 Сохранить" Width="120" Height="40"
                            Background="#27AE60" Foreground="White" Margin="0,0,10,0"
                            Click="BtnSave_Click"/>
                    <Button Content="❌ Отмена" Width="100" Height="40"
                            Background="#95A5A6" Foreground="White"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
