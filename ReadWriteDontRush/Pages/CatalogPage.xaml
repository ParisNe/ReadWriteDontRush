<Page x:Class="ReadWriteDontRush.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage" Background="White">

    <Page.Resources>
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Поиск" FontSize="12" Foreground="Gray"/>
                    <TextBox x:Name="TxtSearch" Margin="0,5,0,0" Height="35" 
                             TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Сортировка" FontSize="12" Foreground="Gray"/>
                    <ComboBox x:Name="CmbSort" Height="35" SelectedIndex="0"
                              SelectionChanged="CmbSort_SelectionChanged">
                        <ComboBoxItem Content="По названию (А-Я)"/>
                        <ComboBoxItem Content="По названию (Я-А)"/>
                        <ComboBoxItem Content="По рейтингу (высокий)"/>
                        <ComboBoxItem Content="По рейтингу (низкий)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Фильтр по жанру" FontSize="12" Foreground="Gray"/>
                    <ComboBox x:Name="CmbGenre" Height="35" 
                              SelectionChanged="CmbGenre_SelectionChanged"/>
                </StackPanel>

                <Button x:Name="BtnReset" Grid.Column="3" Content="Сбросить" 
                        Width="80" Height="35" Margin="10,22,0,0"
                        Background="#E74C3C" Foreground="White"
                        Click="BtnReset_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksItemsControl" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Style="{StaticResource BookCardStyle}">
                            <StackPanel>
                                <Border Height="250" Background="#ECF0F1" CornerRadius="8,8,0,0">
                                    <Image Width="180" Height="230" Margin="10,10,10,10"
                                           Stretch="UniformToFill">
                                        <Image.Source>
                                            <Binding Path="CoverImagePath">

                                            </Binding>
                                        </Image.Source>
                                    </Image>
                                </Border>

                                <StackPanel Margin="10" Height="120">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                               FontSize="14" TextWrapping="Wrap"
                                               Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Author.DisplayName}" 
                                               FontSize="11" Foreground="Gray"
                                               Margin="0,0,0,5"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="★" Foreground="Gold" FontSize="14"/>
                                        <TextBlock Text="{Binding AverageRating, StringFormat={}{0:F1}}" 
                                                   FontSize="12" Margin="5,0,0,0"/>
                                        <TextBlock Text="{Binding ReviewsCount, StringFormat='(отзывов: {0})'}" 
                                                   FontSize="10" Foreground="Gray" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding GenresString}" FontSize="10" 
                                               Foreground="#7F8C8D" TextWrapping="Wrap"
                                               MaxHeight="40"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Читать" Width="80" Height="30"
                                                Background="#3498DB" Foreground="White"
                                                Click="BtnRead_Click" Tag="{Binding}"/>
                                        <Button Content="В список" Width="80" Height="30"
                                                Margin="5,0,0,0" Background="#2C3E50" 
                                                Foreground="White" Click="BtnAddToList_Click" 
                                                Tag="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
