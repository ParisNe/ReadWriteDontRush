<Page x:Class="ReadWriteDontRush.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage" Background="White">

    <Grid >

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <Border Grid.Row="0"
            Background="White"
            Padding="20"
            Margin="0,0,0,10">

            <WrapPanel VerticalAlignment="Center">

                <TextBox x:Name="TxtSearch"
                     Width="220"
                     Height="36"
                     Margin="0,0,10,0"/>

                <ComboBox x:Name="CmbSort"
                      Width="180"
                      Height="36"
                      Margin="0,0,10,0"/>

                <ComboBox x:Name="CmbGenre"
                      Width="180"
                      Height="36"
                      Margin="0,0,10,0"/>

                <Button x:Name="BtnReset"
                    Content="Сброс"
                    Width="90"
                    Height="36"
                    Background="#EAEAEA"
                    Foreground="#222"
                    BorderThickness="0"/>

            </WrapPanel>
        </Border>

        <!-- Книги -->
        <ScrollViewer Grid.Row="1">

            <ItemsControl x:Name="BooksItemsControl"
                      Margin="10">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Width="210"
                            Margin="10"
                            Background="White"
                            CornerRadius="8"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1">

                            <StackPanel>

                                <!-- Обложка -->
                                <Border Height="260"
                                    Background="#ECECEC"
                                    CornerRadius="8,8,0,0">

                                    <Image Stretch="UniformToFill"/>
                                </Border>

                                <!-- Информация -->
                                <StackPanel Margin="12">

                                    <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding AuthorName}"
                                           Margin="0,4,0,8"
                                           Foreground="#666"
                                           FontSize="12"/>

                                    <TextBlock Text="{Binding GenresString}"
                                           FontSize="11"
                                           Foreground="#888"
                                           Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal">

                                        <Button Content="Читать"
                                            Width="85"
                                            Height="34"
                                            Background="#3B82F6"
                                            Foreground="White"
                                            BorderThickness="0"/>

                                        <Button Content="+ Список"
                                            Width="85"
                                            Height="34"
                                            Margin="8,0,0,0"
                                            Background="#EAEAEA"
                                            Foreground="#222"
                                            BorderThickness="0"/>

                                    </StackPanel>

                                </StackPanel>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>
    </Grid>
</Page>
