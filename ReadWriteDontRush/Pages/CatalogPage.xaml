<Page x:Class="ReadWriteDontRush.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage" Background="White">

    <Page.Resources>
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </Page.Resources>

    <Grid Background="#E8ECEF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров с тенью -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,15" 
                CornerRadius="0" >
            <Border.Resources>
                <DropShadowEffect x:Key="HeaderShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
            </Border.Resources>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="🔍 Поиск" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtSearch" Margin="0,0,0,0" Height="38" 
                             FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"
                             TextChanged="TxtSearch_TextChanged">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <!-- Сортировка -->
                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="📊 Сортировка" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbSort" Height="38" FontSize="13" BorderBrush="#BDC3C7" BorderThickness="1"
                              SelectionChanged="CmbSort_SelectionChanged">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="По названию (А-Я)"/>
                        <ComboBoxItem Content="По названию (Я-А)"/>
                        <ComboBoxItem Content="По рейтингу (высокий)"/>
                        <ComboBoxItem Content="По рейтингу (низкий)"/>
                    </ComboBox>
                </StackPanel>

                <!-- Фильтр по жанру -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="🏷️ Фильтр по жанру" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbGenre" Height="38" FontSize="13" BorderBrush="#BDC3C7" BorderThickness="1"
                              SelectionChanged="CmbGenre_SelectionChanged">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <!-- Кнопка сброса -->
                <Button x:Name="BtnReset" Grid.Column="3" Content="↺ Сбросить" 
                        Width="90" Height="38" Margin="15,22,0,0"
                        Background="#95A5A6" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="BtnReset_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Список книг -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksItemsControl" Margin="15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Style="{StaticResource BookCardStyle}">
                            <StackPanel>
                                <!-- Обложка -->
                                <Border Height="280" Background="#F0F2F5" CornerRadius="12,12,0,0">
                                    <Image Width="200" Height="260" Margin="10,10,10,10"
                                           Stretch="UniformToFill">
                                        <Image.Source>
                                            <Binding Path="CoverImagePath">
                                            </Binding>
                                        </Image.Source>
                                    </Image>
                                </Border>

                                <!-- Информация о книге -->
                                <StackPanel Margin="12" Height="150">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                               FontSize="15" TextWrapping="Wrap"
                                               Margin="0,0,0,6" Foreground="#1E2A38"/>
                                    <TextBlock Text="{Binding Author.DisplayName}" 
                                               FontSize="12" Foreground="#7F8C8D"
                                               Margin="0,0,0,6"/>

                                    <!-- Рейтинг -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="★" Foreground="#F1C40F" FontSize="16"/>
                                        <TextBlock Text="{Binding AverageRating, StringFormat={}{0:F1}}" 
                                                   FontSize="13" Margin="5,0,0,0" Foreground="#555"/>
                                        <TextBlock Text="{Binding ReviewsCount, StringFormat='({0})'}" 
                                                   FontSize="11" Foreground="#95A5A6" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <!-- Жанры -->
                                    <TextBlock Text="{Binding GenresString}" FontSize="11" 
                                               Foreground="#7F8C8D" TextWrapping="Wrap"
                                               MaxHeight="36"/>

                                    <!-- Кнопки действий -->
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="📖 Читать" Width="85" Height="34"
                                                Background="#3498DB" Foreground="White" FontSize="11"
                                                Cursor="Hand" BorderThickness="0" Click="BtnRead_Click" Tag="{Binding}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Button Content="➕ В список" Width="85" Height="34"
                                                Margin="8,0,0,0" Background="#2C3E50" FontSize="11"
                                                Foreground="White" Cursor="Hand" BorderThickness="0" 
                                                Click="BtnAddToList_Click" Tag="{Binding}">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
