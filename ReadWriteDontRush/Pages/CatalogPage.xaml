<Page x:Class="ReadWriteDontRush.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage" Background="White">

    <StackPanel Orientation="Horizontal">

        <TextBox x:Name="SearchBox"
                 Width="200"
                 Margin="5"
                 TextChanged="FilterChanged"/>

        <ComboBox x:Name="SortBox"
                  Width="150"
                  SelectionChanged="FilterChanged">

            <ComboBoxItem Content="По имени"/>
            <ComboBoxItem Content="По рейтингу"/>

        </ComboBox>

        <ComboBox x:Name="GenreBox"
                  Width="150"
                  SelectionChanged="FilterChanged"/>

    </StackPanel>

    <ScrollViewer Grid.Row="1">

        <ItemsControl x:Name="BooksList">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <Border Width="180"
                            Margin="10"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <StackPanel>

                            <Image Height="220"
                                   Source="{Binding CoverUrl}"/>

                            <TextBlock Text="{Binding Title}"
                                       FontWeight="Bold"
                                       Margin="5"/>

                            <TextBlock Text="{Binding AverageRating}"
                                       Margin="5"/>

                            <Button Content="Открыть"
                                    Tag="{Binding Id}"
                                    Click="OpenBook_Click"/>

                            <Button Content="Добавить в список"
                                    Tag="{Binding Id}"
                                    Click="AddToList_Click"/>

                        </StackPanel>

                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </ScrollViewer>
</Page>
