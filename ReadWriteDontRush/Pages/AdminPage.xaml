<Page x:Class="ReadWriteDontRush.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage" Background="White">

    <TabControl Margin="10">

        <TabItem Header="Жалобы">

            <DataGrid x:Name="ComplaintsGrid"
                  AutoGenerateColumns="True"/>

        </TabItem>

        <TabItem Header="Разморозка">

            <DataGrid x:Name="UnfreezeGrid"
                  AutoGenerateColumns="True"/>

        </TabItem>

        <TabItem Header="Авторы">

            <DataGrid x:Name="AuthorRequestsGrid"
                  AutoGenerateColumns="True"/>

        </TabItem>

        <TabItem Header="Пользователи">

            <DataGrid x:Name="UsersGrid"
                  AutoGenerateColumns="True"/>

        </TabItem>

    </TabControl>

</Page>
