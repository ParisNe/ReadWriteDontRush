<Page x:Class="ReadWriteDontRush.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage" Background="White">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Жалобы"
                   FontSize="24"/>

        <DataGrid x:Name="ComplaintsGrid"
                  Grid.Row="1"
                  Margin="0 10"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0 10">

            <Button Content="Заморозить"
                    Width="150"
                    Height="35"
                    Margin="0 0 10 0"
                    Click="FreezeUserBtn_Click"/>

            <Button Content="Разморозить"
                    Width="150"
                    Height="35"
                    Click="UnfreezeUserBtn_Click"/>

        </StackPanel>

        <DataGrid x:Name="UsersGrid"
                  Grid.Row="3"
                  Margin="0 10 0 0"/>

    </Grid>

</Page>
