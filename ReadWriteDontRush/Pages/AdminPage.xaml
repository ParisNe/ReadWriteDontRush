<Page x:Class="ReadWriteDontRush.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage" Background="White">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </Page.Resources>

    <Grid Background="#E8ECEF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с градиентом -->
        <Border Grid.Row="0" Background="#1E2A38" Padding="20" CornerRadius="0">
            <TextBlock Text="⚙️ Панель администратора" FontSize="28" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Вкладки с улучшенным дизайном -->
        <TabControl Grid.Row="1" Margin="15" Background="White" BorderBrush="#E8ECEF" BorderThickness="1">
            <!-- Вкладка 1: Жалобы -->
            <TabItem Header="📋 Жалобы" Style="{StaticResource TabItemStyle}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Список жалоб" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1E2A38"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ComplaintsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="15" Foreground="#2C3E50">
                                                <Run Text="👤 От: "/>
                                                <Run Text="{Binding UserDisplayName}" Foreground="#3498DB"/>
                                            </TextBlock>

                                            <Border Grid.Row="1" Background="#FDEDEC" CornerRadius="5" Padding="6" Margin="0,8,0,8">
                                                <TextBlock>
                                                    <Run Text="⚠️ Тип: "/>
                                                    <Run Text="{Binding ComplaintType}" Foreground="#E74C3C" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </Border>

                                            <TextBlock Grid.Row="2" Text="{Binding Reason}" 
                                                       TextWrapping="Wrap" Margin="0,5,0,12" FontSize="13" Foreground="#555"/>

                                            <StackPanel Grid.Row="3" Orientation="Horizontal">
                                                <Button Content="✅ Принять" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#27AE60" Foreground="White" Margin="0,0,12,0"
                                                        Click="AcceptComplaint_Click" Tag="{Binding ComplaintID}"/>
                                                <Button Content="❌ Отклонить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#E74C3C" Foreground="White"
                                                        Click="RejectComplaint_Click" Tag="{Binding ComplaintID}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="TxtNoComplaints" Text="✅ Нет активных жалоб" 
                               Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Foreground="#95A5A6" FontSize="16" FontWeight="SemiBold"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Заявки на смену роли -->
            <TabItem Header="👨‍🎨 Заявки на смену роли" Style="{StaticResource TabItemStyle}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="👨‍🎨 Список заявок на смену роли" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1E2A38"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AuthorRequestsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="15" Foreground="#2C3E50">
                                                <Run Text="👤 Пользователь: "/>
                                                <Run Text="{Binding UserDisplayName}" Foreground="#3498DB"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="1" Margin="0,8,0,8" FontSize="13">
                                                <Run Text="📌 Текущая роль: "/>
                                                <Run Text="{Binding CurrentRoleName}" Foreground="#7F8C8D"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2" Margin="0,0,0,12" FontSize="13">
                                                <Run Text="📅 Дата подачи: "/>
                                                <Run Text="{Binding RequestDate, StringFormat='dd.MM.yyyy'}" Foreground="#7F8C8D"/>
                                            </TextBlock>

                                            <StackPanel Grid.Row="3" Orientation="Horizontal">
                                                <Button Content="✅ Одобрить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#27AE60" Foreground="White" Margin="0,0,12,0"
                                                        Click="AcceptAuthorRequest_Click" Tag="{Binding RequestID}"/>
                                                <Button Content="❌ Отклонить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#E74C3C" Foreground="White"
                                                        Click="RejectAuthorRequest_Click" Tag="{Binding RequestID}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="TxtNoAuthorRequests" Text="✅ Нет активных заявок" 
                               Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Foreground="#95A5A6" FontSize="16" FontWeight="SemiBold"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Заявки на разморозку -->
            <TabItem Header="❄️ Заявки на разморозку" Style="{StaticResource TabItemStyle}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="❄️ Список заявок на разморозку" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1E2A38"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="UnfreezeRequestsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="15" Foreground="#2C3E50">
                                                <Run Text="👤 Пользователь: "/>
                                                <Run Text="{Binding UserDisplayName}" Foreground="#3498DB"/>
                                            </TextBlock>

                                            <Border Grid.Row="1" Background="#FDEBD0" CornerRadius="5" Padding="6" Margin="0,8,0,8">
                                                <TextBlock>
                                                    <Run Text="🔸 Тип: "/>
                                                    <Run Text="{Binding RequestType}" Foreground="#E67E22" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </Border>

                                            <TextBlock Grid.Row="2" Text="{Binding Reason}" 
                                                       TextWrapping="Wrap" Margin="0,5,0,12" FontSize="13" Foreground="#555"/>

                                            <StackPanel Grid.Row="3" Orientation="Horizontal">
                                                <Button Content="✅ Разморозить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#27AE60" Foreground="White" Margin="0,0,12,0"
                                                        Click="AcceptUnfreezeRequest_Click" Tag="{Binding UnfreezeRequestID}"/>
                                                <Button Content="❌ Отклонить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#E74C3C" Foreground="White"
                                                        Click="RejectUnfreezeRequest_Click" Tag="{Binding UnfreezeRequestID}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="TxtNoUnfreezeRequests" Text="✅ Нет активных заявок" 
                               Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Foreground="#95A5A6" FontSize="16" FontWeight="SemiBold"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 4: Замороженные книги -->
            <TabItem Header="📚 Замороженные книги" Style="{StaticResource TabItemStyle}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📚 Список замороженных книг" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1E2A38"/>

                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="0" Margin="0,0,0,15">
                        <TextBox x:Name="TxtFrozenBookSearch" Height="38" FontSize="13" Padding="10"
                                 BorderBrush="#BDC3C7" BorderThickness="1"
                                 TextChanged="TxtFrozenBookSearch_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FrozenBooksItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="15" Foreground="#C0392B">
                                                <Run Text="📕 "/>
                                                <Run Text="{Binding Title}"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="1" Margin="0,8,0,8" FontSize="13">
                                                <Run Text="✍️ Автор: "/>
                                                <Run Text="{Binding AuthorName}" Foreground="#3498DB"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2" Margin="0,0,0,8" FontSize="12">
                                                <Run Text="🏷️ Жанры: "/>
                                                <Run Text="{Binding GenresString}" Foreground="#7F8C8D"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="3" Margin="0,0,0,12" FontSize="12">
                                                <Run Text="❄️ Дата заморозки: "/>
                                                <Run Text="{Binding FrozenDate, StringFormat='dd.MM.yyyy'}" Foreground="#7F8C8D"/>
                                            </TextBlock>

                                            <StackPanel Grid.Row="4" Orientation="Horizontal">
                                                <Button Content="🔓 Разморозить" Width="120" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#27AE60" Foreground="White"
                                                        Click="UnfreezeBook_Click" Tag="{Binding BookID}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="TxtNoFrozenBooks" Text="📭 Нет замороженных книг" 
                               Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Foreground="#95A5A6" FontSize="16" FontWeight="SemiBold"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 5: Управление пользователями -->
            <TabItem Header="👥 Пользователи" Style="{StaticResource TabItemStyle}">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="👥 Управление пользователями" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1E2A38"/>

                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="0" Margin="0,0,0,15">
                        <TextBox x:Name="TxtUserSearch" Height="38" FontSize="13" Padding="10"
                                 BorderBrush="#BDC3C7" BorderThickness="1"
                                 TextChanged="TxtUserSearch_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="UsersItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="Bold" FontSize="15" Foreground="#2C3E50">
                                                <Run Text="👤 "/>
                                                <Run Text="{Binding DisplayName}"/>
                                                <Run Text=" (@"/>
                                                <Run Text="{Binding Login}"/>
                                                <Run Text=")"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,8" FontSize="13">
                                                <Run Text="📧 "/>
                                                <Run Text="{Binding Email}" Foreground="#7F8C8D"/>
                                            </TextBlock>

                                            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#E8F8F5" CornerRadius="5" Padding="8" Margin="0,0,0,12">
                                                <TextBlock FontSize="12">
                                                    <Run Text="⭐ Роль: "/>
                                                    <Run Text="{Binding RoleName}" Foreground="#3498DB" FontWeight="SemiBold"/>
                                                    <Run Text=" | 🔔 Статус: "/>
                                                    <Run Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </Border>

                                            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal">
                                                <Button Content="🔄 Сменить роль" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#3498DB" Foreground="White" Margin="0,0,12,0"
                                                        Click="ChangeRole_Click" Tag="{Binding UserID}"/>
                                                <Button Content="🔒 Заморозить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#E74C3C" Foreground="White" Margin="0,0,12,0"
                                                        Click="FreezeUser_Click" Tag="{Binding UserID}"/>
                                                <Button Content="🔑 Сбросить пароль" Width="120" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#F39C12" Foreground="White"
                                                        Click="ResetPassword_Click" Tag="{Binding UserID}"/>
                                                <Button Content="🔓 Разморозить" Width="110" 
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#27AE60" Foreground="White" Margin="12,0,0,0"
                                                        Click="UnfreezeUser_Click" Tag="{Binding UserID}"
                                                        Visibility="{Binding IsFrozen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
