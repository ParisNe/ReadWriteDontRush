<Page x:Class="ReadWriteDontRush.Pages.UserProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReadWriteDontRush.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserProfilePage" Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Информация о пользователе -->
            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="👤 Профиль пользователя" FontSize="24" FontWeight="Bold" 
                               Margin="0,0,0,20" Foreground="#2C3E50"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Имя:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Column="1" x:Name="TxtDisplayName" Margin="0,5"/>

                        <TextBlock Grid.Column="0" Text="Логин:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Column="1" x:Name="TxtLogin" Margin="0,5"/>

                        <TextBlock Grid.Column="0" Text="Email:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Column="1" x:Name="TxtEmail" Margin="0,5"/>

                        <TextBlock Grid.Column="0" Text="Роль:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Column="1" x:Name="TxtRole" Margin="0,5"/>

                        <TextBlock Grid.Column="0" Text="Дата регистрации:" FontWeight="Bold" Margin="0,5"/>
                        <TextBlock Grid.Column="1" x:Name="TxtCreatedAt" Margin="0,5"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Предупреждение о заморозке -->
            <Border x:Name="FreezeWarning" Grid.Row="1" Background="#FFE5E5" 
                    CornerRadius="10" Padding="20" Margin="0,0,0,20"
                    BorderBrush="#E74C3C" BorderThickness="2" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="⚠️ ВАШ АККАУНТ ЗАМОРОЖЕН" FontWeight="Bold" 
                               FontSize="16" Foreground="#E74C3C" Margin="0,0,0,10"/>
                    <TextBlock Text="Причина:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtFreezeReason" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <Button Content="📝 Оспорить заморозку" Width="150" Height="35"
                            Background="#E67E22" Foreground="White"
                            Click="BtnAppealFreeze_Click"/>
                </StackPanel>
            </Border>

            <!-- Отзывы пользователя -->
            <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="📝 Мои отзывы" FontSize="20" FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <Button x:Name="BtnRequestAuthor" Content="📖 Подать заявку на роль Автора" 
                            Width="220" Height="40" Background="#3498DB" Foreground="White"
                            Margin="0,0,0,15" Click="BtnRequestAuthor_Click"
                            Visibility="Collapsed"/>

                    <ItemsControl x:Name="ReviewsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" CornerRadius="5" 
                                        Padding="15" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" FontSize="14">
                                            <Run Text="{Binding BookTitle}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                            <TextBlock Text="★" Foreground="Gold" FontSize="14"/>
                                            <TextBlock Text="{Binding Rating}" FontSize="12" Margin="5,0,0,0"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=' dd.MM.yyyy'}" 
                                                       FontSize="11" Foreground="Gray" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ReviewText}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="TxtNoReviews" Text="У вас пока нет отзывов" 
                               HorizontalAlignment="Center" Foreground="Gray"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
