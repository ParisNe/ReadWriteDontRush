<Window x:Class="ReadWriteDontRush.ReasonInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReadWriteDontRush"
        mc:Ignorable="d"
        Title="ReasonInputWindow" Height="450" Width="800">
    <Grid>
        <!-- Тень для основного контента -->
        <Border Background="White" Margin="10" CornerRadius="8">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок с иконкой -->
                <Border Grid.Row="0" Background="#FF6B6B" CornerRadius="6" Height="50" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚠️ " FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock 
                            Text="Укажите причину жалобы" 
                            FontWeight="Bold" 
                            FontSize="16" 
                            Foreground="White"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Поле для ввода с улучшенным дизайном -->
                <TextBox x:Name="TxtReason" 
                     Grid.Row="1" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto"
                     BorderBrush="#DDDDDD"
                     BorderThickness="1"
                     Padding="10"
                     FontSize="13"
                     Background="#FAFAFA"
                     CaretBrush="#FF6B6B">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Кнопки с улучшенным стилем -->
                <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">

                    <Button x:Name="BtnOk" 
                        Content="✓ Отправить" 
                        Width="110" 
                        Height="38"
                        Background="#27AE60" 
                        Foreground="White"
                        Click="BtnOk_Click"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        FontSize="13">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnCancel" 
                        Content="✗ Отмена" 
                        Width="100" 
                        Height="38"
                        Margin="10,0,0,0"
                        Click="BtnCancel_Click"
                        Cursor="Hand"
                        Background="#E74C3C"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="13">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <!-- Эффект тени -->
    <Window.Resources>
        <DropShadowEffect x:Key="ShadowEffect" 
                         BlurRadius="15" 
                         ShadowDepth="2" 
                         Opacity="0.2" 
                         Color="Black"/>
    </Window.Resources>
</Window>
